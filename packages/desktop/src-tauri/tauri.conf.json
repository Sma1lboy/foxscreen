{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "foxscreen",
	"version": "0.1.0",
	"identifier": "com.foxscreen.app",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:17420",
		"beforeDevCommand": "bun run dev:web",
		"beforeBuildCommand": "bun run build:web"
	},
	"app": {
		"windows": [
			{
				"title": "foxscreen",
				"width": 1280,
				"height": 820,
				"minWidth": 900,
				"minHeight": 600,
				"resizable": true,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true,
				"trafficLightPosition": { "x": 16, "y": 18 }
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": ["**"]
			}
		}
	},
	"bundle": {
		"active": false,
		"targets": "all"
	}
}
