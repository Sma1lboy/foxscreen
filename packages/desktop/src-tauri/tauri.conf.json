{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "foxscreen",
	"version": "0.1.0",
	"identifier": "com.foxscreen.app",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:17420",
		"beforeDevCommand": "bun run dev:web",
		"beforeBuildCommand": "bun run build:web"
	},
	"app": {
		"windows": [
			{
				"title": "foxscreen",
				"width": 1280,
				"height": 820,
				"minWidth": 900,
				"minHeight": 600,
				"resizable": true,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true,
				"trafficLightPosition": { "x": 16, "y": 18 }
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": ["**"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"shortDescription": "AI video editor — import, transcript-driven cut, timeline, export",
		"longDescription": "foxscreen — a cross-platform AI video editor: import any video, transcript-driven keep/cut, a standard multi-track timeline, and export.",
		"windows": {
			"nsis": {
				"installMode": "currentUser"
			}
		}
	}
}
