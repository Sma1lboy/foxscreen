{
	"name": "@foxscreen/desktop",
	"private": true,
	"version": "1.5.0",
	"type": "module",
	"description": "foxscreen desktop app — openscreen-derived Tauri recorder/editor with the cutti engine.",
	"scripts": {
		"dev": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev",
		"dev:web": "CUTTIO_SHELL=tauri vite",
		"build:web": "CUTTIO_SHELL=tauri vite build",
		"tauri:dev": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev",
		"tauri:build": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build",
		"build": "tsc && CUTTIO_SHELL=tauri vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"test": "vitest --run",
		"test:browser": "vitest --config vitest.browser.config.ts --run",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@foxscreen/cutti-core": "workspace:*"
	}
}
