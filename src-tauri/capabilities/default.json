{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "cuttio default capability — file IO, dialogs, os, shell open",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "os:default",
    "dialog:default",
    "shell:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/**",
        "$DOWNLOAD/**",
        "$DESKTOP/**",
        "$DOCUMENT/**",
        "$VIDEO/**",
        "$PICTURE/**",
        "$TEMP/**",
        "$APPDATA/**",
        "$APPLOCALDATA/**",
        "$RESOURCE/**"
      ]
    }
  ]
}
